{
    "name": "phenomenon-react-ts-template",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "engines": {
        "node": ">=22.0.0",
        "npm": ">=10.9.0"
    },
    "scripts": {
        "dev:vite": "vite --host",
        "dev:vite:scan": "vite --host --mode scan",
        "dev:tsc": "tsc --build --watch",
        "dev": "run-p dev:vite dev:tsc",
        "dev:scan": "run-p dev:vite:scan dev:tsc",
        "build": "vite build",
        "preview": "vite preview --host",
        "tsc": "tsc --build",
        "lint:eslint": "eslint --cache --max-warnings 0 --report-unused-disable-directives \"**/*.{js,ts,tsx,cjs,mjs}\"",
        "lint:stylelint": "stylelint --cache -q \"**/*.css\"",
        "lint:prettier": "prettier --check \"**/*.{js,ts,tsx,json,html,css,cjs,mjs}\"",
        "lint": "run-s lint:*",
        "fix:prettier": "prettier --write \"**/*.{js,ts,tsx,json,html,css,cjs,mjs}\"",
        "prepare": "husky"
    },
    "dependencies": {
        "@base-ui/react": "^1.2.0",
        "@csstools/postcss-global-data": "^4.0.0",
        "@fontsource/poppins": "^5.2.7",
        "@react-hookz/web": "^25.2.0",
        "@svg-use/react": "^1.1.0",
        "@tanstack/react-form": "^1.27.7",
        "@tanstack/react-hotkeys": "^0.4.0",
        "@tanstack/react-query": "^5.90.16",
        "@tanstack/react-router": "^1.147.3",
        "clsx": "^2.1.1",
        "ky": "^1.14.2",
        "motion": "^12.38.0",
        "postcss-custom-media": "^12.0.1",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "sonner": "^2.0.7",
        "zod": "4.3.5"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.3.1",
        "@commitlint/config-conventional": "^20.3.1",
        "@eslint/js": "^9.39.2",
        "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
        "@svg-use/vite": "^1.1.0",
        "@tanstack/devtools-vite": "^0.4.1",
        "@tanstack/eslint-plugin-query": "^5.91.2",
        "@tanstack/eslint-plugin-router": "^1.141.0",
        "@tanstack/react-devtools": "^0.9.2",
        "@tanstack/react-query-devtools": "^5.91.2",
        "@tanstack/react-router-devtools": "^1.149.0",
        "@tanstack/router-devtools": "^1.149.0",
        "@tanstack/router-plugin": "^1.149.0",
        "@types/node": "^25.0.6",
        "@types/react": "^19.2.8",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.2",
        "autoprefixer": "^10.4.23",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "globals": "^17.0.0",
        "husky": "^9.1.7",
        "npm-run-all": "^4.1.5",
        "postcss": "^8.5.6",
        "prettier": "^3.7.4",
        "rollup-plugin-visualizer": "^6.0.5",
        "stylelint": "^16.26.1",
        "stylelint-config-standard": "^39.0.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.52.0",
        "vite": "^7.3.1",
        "vite-plugin-eslint2": "^5.0.4",
        "vite-plugin-html": "^3.2.2"
    }
}
